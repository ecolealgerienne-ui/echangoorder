<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_x_batch_picking_settings_wizard_form" model="ir.ui.view">
        <field name="name">x_batch_picking_settings_wizard.form</field>
        <field name="model">x_batch_picking_settings_wizard</field>
        <field name="arch" type="xml">
            <form string="Préparation groupée — paramètres">
                <group string="Contraintes du lot">
                    <field name="batch_max_orders"/>
                    <field name="batch_max_qty"/>
                    <field name="batch_max_lines"/>
                </group>
                <group string="Regroupement">
                    <field name="batch_min_similarity"/>
                    <field name="batch_sla_hours"/>
                </group>
                <footer>
                    <button name="action_save" type="object" string="Enregistrer" class="btn-primary"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_x_batch_picking_settings_wizard" model="ir.actions.act_window">
        <field name="name">Paramètres de préparation groupée</field>
        <field name="res_model">x_batch_picking_settings_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_echango_batch_picking_settings" name="Paramètres de préparation groupée"
              parent="menu_echango_order_root" action="action_x_batch_picking_settings_wizard" sequence="21"/>
</odoo>
