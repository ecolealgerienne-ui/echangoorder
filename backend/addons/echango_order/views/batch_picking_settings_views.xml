<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue dédiée, volontairement en dehors du formulaire géant de
         Réglages général (base.res_config_settings_view_form) — un menu
         direct sous "Echango Order" suffit pour ce besoin, pas besoin
         d'intégrer une section dans l'app Réglages standard. -->
    <record id="view_echango_batch_picking_settings_form" model="ir.ui.view">
        <field name="name">echango_order.batch_picking.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Préparation groupée — paramètres">
                <group string="Contraintes du lot">
                    <field name="x_batch_max_orders"/>
                    <field name="x_batch_max_qty"/>
                    <field name="x_batch_max_lines"/>
                </group>
                <group string="Regroupement">
                    <field name="x_batch_min_similarity"/>
                    <field name="x_batch_sla_hours"/>
                </group>
                <footer>
                    <button name="execute" type="object" string="Enregistrer" class="btn-primary"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_echango_batch_picking_settings" model="ir.actions.act_window">
        <field name="name">Paramètres de préparation groupée</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_echango_batch_picking_settings_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_echango_batch_picking_settings" name="Paramètres de préparation groupée"
              parent="menu_echango_order_root" action="action_echango_batch_picking_settings" sequence="21"/>
</odoo>
