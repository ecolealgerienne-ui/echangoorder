<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_x_delivery_zone_list" model="ir.ui.view">
        <field name="name">x_delivery_zone.list</field>
        <field name="model">x_delivery_zone</field>
        <field name="arch" type="xml">
            <list string="Zones de livraison">
                <field name="name"/>
                <field name="city"/>
                <field name="zip_code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_x_delivery_zone_form" model="ir.ui.view">
        <field name="name">x_delivery_zone.form</field>
        <field name="model">x_delivery_zone</field>
        <field name="arch" type="xml">
            <form string="Zone de livraison">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="city"/>
                        <field name="zip_code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_x_delivery_zone" model="ir.actions.act_window">
        <field name="name">Zones de livraison</field>
        <field name="res_model">x_delivery_zone</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_echango_order_root" name="Echango Order" sequence="90"/>
    <menuitem id="menu_x_delivery_zone" name="Zones de livraison"
              parent="menu_echango_order_root" action="action_x_delivery_zone"/>
</odoo>
