<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Qualité clients — un modérateur valide/rejette manuellement chaque
         nouveau compte client (statusbar + boutons sur la fiche contact
         standard) avant qu'il puisse passer commande, voir
         controllers/checkout_controller.py. -->
    <record id="view_partner_form_x_verification" model="ir.ui.view">
        <field name="name">res.partner.form.x.verification</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_verify_customer" type="object" string="Valider le client"
                            class="oe_highlight" invisible="x_verification_state == 'verified'"/>
                    <button name="action_reject_customer" type="object" string="Rejeter le client"
                            invisible="x_verification_state == 'rejected'"/>
                    <field name="x_verification_state" widget="statusbar" statusbar_visible="pending,verified"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="action_partner_pending_verification" model="ir.actions.act_window">
        <field name="name">Clients à valider</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_ids', '!=', False), ('x_verification_state', '!=', 'verified')]</field>
    </record>

    <menuitem id="menu_partner_pending_verification" name="Clients à valider"
              parent="menu_echango_order_root" action="action_partner_pending_verification" sequence="10"/>
</odoo>
