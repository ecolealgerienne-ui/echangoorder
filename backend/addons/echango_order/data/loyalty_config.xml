<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sans ce paramètre, `loyalty.reward.all_discount_product_ids` reste
         vide (voir loyalty/models/loyalty_reward.py) et ce quels que soient
         les produits choisis dans "S'applique à > Produits spécifiques" —
         ni le badge Promo (catalog_controller.py), ni l'application réelle
         de la remise par Odoo sur la commande ne fonctionnent sans lui.
         `set_param` (et non un `<record>` direct) : la clé existe déjà en
         base (créée par `loyalty`/`sale_loyalty` avec la valeur par défaut
         "disabled"), un `<record>` en création provoquerait une violation
         de contrainte d'unicité sur `key`. `set_param` crée ou met à jour
         selon le cas, et est réappliqué à chaque mise à jour du module
         (pas de noupdate) : purement technique, aucune raison de vouloir
         "disabled" côté Echango Order. -->
    <function model="ir.config_parameter" name="set_param"
              eval="('loyalty.compute_all_discount_product_ids', 'enabled')"/>
</odoo>
