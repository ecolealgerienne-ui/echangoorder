<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sans ce paramètre, `loyalty.reward.all_discount_product_ids` reste
         vide (voir loyalty/models/loyalty_reward.py) et ce quels que soient
         les produits choisis dans "S'applique à > Produits spécifiques" —
         ni le badge Promo (catalog_controller.py), ni l'application réelle
         de la remise par Odoo sur la commande ne fonctionnent sans lui.
         Forcé à chaque mise à jour du module (pas de noupdate) : purement
         technique, aucune raison de vouloir "disabled" côté Echango Order. -->
    <record id="param_loyalty_compute_all_discount_product_ids" model="ir.config_parameter">
        <field name="key">loyalty.compute_all_discount_product_ids</field>
        <field name="value">enabled</field>
    </record>
</odoo>
